{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "your_connection_string_here"
  },
  "WincheStorage": {
    "S3Archive": {
      "BucketName": "your_bucket_name_here",
      "AccessKey": "your_access_key_here",
      "SecretKey": "your_secret_key_here",
      "RegionName": "your_region_name_here"
    }
  }
}
